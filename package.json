{
  "name": "mcp-spec-check",
  "version": "0.1.0",
  "description": "Is your remote MCP server ready for the MCP 2026-07-28 spec release? Zero-install black-box readiness probe.",
  "type": "module",
  "bin": {
    "mcp-spec-check": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "refs:install": "npm --prefix ref-servers install",
    "refs:old": "npm --prefix ref-servers run start:old",
    "refs:rc": "npm --prefix ref-servers run start:rc",
    "verify:refs": "tsx scripts/verify-refs.ts",
    "verify:conformance": "npx -y @modelcontextprotocol/conformance@alpha server --url http://127.0.0.1:7102/mcp",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "spec",
    "migration",
    "readiness",
    "cli",
    "2026-07-28"
  ],
  "author": "Roee Tsur",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Roee-Tsur/mcp-spec-check.git"
  },
  "homepage": "https://github.com/Roee-Tsur/mcp-spec-check#readme",
  "bugs": "https://github.com/Roee-Tsur/mcp-spec-check/issues",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
